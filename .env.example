# --- Pagos (mientras estén vacíos, el servidor corre en modo GRATIS de prueba) ---
# Dirección EVM (Base) donde recibes USDC — de tu wallet (ej. Coinbase Wallet / MetaMask)
EVM_PAY_TO=
# Dirección Solana donde recibes USDC — de tu wallet Phantom
SOL_PAY_TO=

# testnet (pruebas, dinero falso) | mainnet (producción, dinero real)
NETWORK_MODE=testnet

# Facilitador x402. Testnet: el de x402.org (gratis, por defecto).
# Mainnet + listado en el Bazaar: facilitador CDP de Coinbase (ver README).
FACILITATOR_URL=https://x402.org/facilitator

# --- Opcionales ---
# API key gratuita de la CMF (api.cmfchile.cl) como respaldo de mindicador.cl
CMF_API_KEY=
# Token gratuito de Banxico para la UDI mexicana (banxico.org.mx/SieAPIRest)
BANXICO_TOKEN=
# Clave secreta (inventa una) para ver contadores de uso en /admin/stats (header X-Admin-Key)
ADMIN_KEY=
# Límite de peticiones por IP por minuto (0 = desactivado). Por defecto 300.
RATE_LIMIT_PER_MIN=300
# Ruta a Chrome/Chromium si no se detecta sola
PUPPETEER_EXECUTABLE_PATH=
# Puerto local
PORT=4402
BASE_URL=http://localhost:4402
